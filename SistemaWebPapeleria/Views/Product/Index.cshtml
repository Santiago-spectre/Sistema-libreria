@model List<SistemaWebPapeleria.Models.Product>
@{
    ViewData["Title"] = "Productos";
    ViewData["Active"] = "Product";
}
@section Styles {
    <style>
        .badge-low {
            background: rgba(255,255,255,0.6);
            color: #f87171;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
        }
    </style>
}

@if (TempData["Error"] != null)
{
    <div style="background: rgba(248,113,113,0.15); border: 1px solid #f87171; color: #f87171; padding: 12px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 13px;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div style="background: rgba(52,211,153,0.15); border: 1px solid #34d399; color: #34d399; padding: 12px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 13px;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<!-- TOPBAR -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <p style="color: rgba(255,255,255,0.4); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Gestión de inventario</p>
        <h4 style="color: #ffffff; font-weight: 700; font-size: 24px;">Productos</h4>
    </div>
    <button onclick="document.getElementById('modalAgregar').style.display='flex'"
            style="background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; letter-spacing: 1px; padding: 10px 20px; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; transition: opacity 0.2s ease;">
        <i class="bi bi-plus-lg"></i> Agregar Producto
    </button>
</div>

<!-- TARJETAS -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 25px;">
    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;">Total Productos</p>
                <h3 style="color: #34d399; font-size: 28px; font-weight: 700;">@ViewBag.TotalProducts</h3>
            </div>
            <div style="background: rgba(52,211,153,0.15); padding: 12px; border-radius: 10px;">
                <i class="bi bi-box-seam-fill" style="color: #34d399; font-size: 22px;"></i>
            </div>
        </div>
    </div>

    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;">Stock Bajo</p>
                <h3 style="color: #fbbf24; font-size: 28px; font-weight: 700;">@ViewBag.LowStock</h3>
            </div>
            <div style="background: rgba(251,191,36,0.15); padding: 12px; border-radius: 10px;">
                <i class="bi bi-exclamation-triangle-fill" style="color: #fbbf24; font-size: 22px;"></i>
            </div>
        </div>
    </div>

    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px;">Agotados</p>
                <h3 style="color: #f87171; font-size: 28px; font-weight: 700;">@ViewBag.OutOfStock</h3>
            </div>
            <div style="background: rgba(248,113,113,0.15); padding: 12px; border-radius: 10px;">
                <i class="bi bi-x-circle-fill" style="color: #f87171; font-size: 22px;"></i>
            </div>
        </div>
    </div>
</div>

<!-- BARRA DE BÚSQUEDA -->
<div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
    <input type="text" id="searchInput" placeholder=" Buscar Producto..." style="flex: 1; min-width: 200px; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
    <select id="filterTipo" style="padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
        <option value="">Todos los tipos</option>
        <option value="Producto">Producto</option>
        <option value="Servicio">Servicio</option>
    </select>
    <select id="filterEstado" style="padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
        <option value="">Todos los estados</option>
        <option value="Activo">Activo</option>
        <option value="Inactivo">Inactivo</option>
    </select>
</div>

<!-- Tabla + categorias-->
<div style="display: grid; grid-template-columns: 1fr 400px; gap: 20px; margin-bottom: 25px;">
    
    <!-- TABLA DE PRODUCTOS -->
    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 25px;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.07);">
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Nombre</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Categoría</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Tipo</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Precio Venta</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Stock</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Estado</th>
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: rgba(255,255,255,0.3); font-size: 13px; padding: 40px;">
                            <i class="bi bi-box-seam" style="font-size: 32px; display: block; margin-bottom: 10px;"></i>
                            No hay productos registrados aún
                        </td>
                    </tr>
                }
                @foreach (var product in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                        <td style="color: #ffffff; font-size: 13px; padding: 12px 15px;">@product.Name</td>
                        <td style="color: rgba(255,255,255,0.6); font-size: 13px; padding: 12px 15px;">@product.Category?.Name</td>
                        <td style="padding: 12px 15px;">
                            @if (product.IsService)
                            {
                                <span style="background: rgba(99,102,241,0.15); color: #6366f1; padding: 3px 10px; border-radius: 20px; font-size: 11px;">Servicio</span>
                            }
                            else
                            {
                                <span style="background: rgba(52,211,153,0.15); color: #34d399; padding: 3px 10px; border-radius: 20px; font-size: 11px;">Producto</span>
                            }
                        </td>
                        <td style="color: #34d399; font-size: 13px; font-weight: 700; padding: 12px 15px;">S/ @product.SalePrice</td>
                        <td style="padding: 12px 15px;">
                            @if (!product.IsService && product.Stock <= product.MinimumStock)
                            {
                                <span class="badge-low">⚠ @product.Stock unid.</span>
                            }
                            else if (product.IsService)
                            {
                                <span style="color: rgba(255,255,255,0.3); font-size: 13px;">-</span>
                            }
                            else
                            {
                                <span style="color: rgba(255,255,255,0.6); font-size: 13px;">@product.Stock unid.</span>
                            }
                        </td>
                        <td style="padding: 12px 15px;">
                            @if (product.IsActive)
                            {
                                <span style="background: rgba(52,211,153,0.15); color: #34d399; padding: 3px 10px; border-radius: 20px; font-size: 11px;">Activo</span>
                            }
                            else
                            {
                                <span style="background: rgba(255,80,80,0.15); color: #ff5050; padding: 3px 10px; border-radius: 20px; font-size: 11px;">Inactivo</span>
                            }
                        </td>
                        <td style="padding: 12px 15px;">
                            <div style="display: flex; gap: 8px;">
                                <button onclick="abrirEditarProducto(@product.ProductId, '@Html.Raw(product.Name)', '@Html.Raw(product.Description)', @product.SalePrice.ToString(System.Globalization.CultureInfo.InvariantCulture), @product.PurchasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture), @product.Stock, @product.MinimumStock, @product.IsService.ToString().ToLower(), @product.CategoryId, '@(product.SupplierId.HasValue ? product.SupplierId.ToString() : "")')"
                                        style="background: rgba(99,102,241,0.15); color: #6366f1; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>
                                <form method="post" action="/Product/ToggleStatus/@product.ProductId" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.5); padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                        @if (product.IsActive)
                                        {
                                            <i class="bi bi-eye-slash-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-eye-fill"></i>
                                        }
                                    </button>
                                </form>
                                <form method="post" action="/Product/Delete/@product.ProductId" style="margin: 0;" onsubmit="return confirm('¿Eliminar este producto?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background: rgba(248,113,113,0.15); color: #f87171; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div id="paginacion" style="display: flex; justify-content: center; gap: 6px; margin-top: 20px;"></div>
    </div>

    <!-- Tarjeta de categorias derecha -->
    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 20px; display: flex; flex-direction: column; gap: 12px; align-self: start; position: sticky; top: 20px; max-height: 80vh; overflow: hidden;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="background: rgba(99,102,241,0.15); padding: 8px; border-radius: 8px;">
                    <i class="bi bi-tags-fill" style="color: #818cf8; font-size: 16px;"></i>
                </div>
                <p style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin: 0;">Categorías</p>
            </div>
            <button onclick="document.getElementById('modalNuevaCategoria').style.display='flex'"
                    style="background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 8px; color: #fff; font-size: 11px; font-weight: 600; padding: 6px 12px; cursor: pointer; display: flex; align-items: center; gap: 5px;">
                <i class="bi bi-plus-lg"></i> Nueva
            </button>
        </div>

        <!-- Lista de categorias -->
        <div style="flex: 1; overflow-y: auto; max-height: calc(80vh - 100px);">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 4px;">
                <span style="color: rgba(255,255,255,0.4); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; width: 30px;">ID</span>
                <span style="color: rgba(255,255,255,0.4); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; flex: 1; padding-left: 8px;">Nombre</span>
                <span style="color: rgba(255,255,255,0.4); font-size: 10px; letter-spacing: 1px; text-transform: uppercase;">Acciones</span>
            </div>
            @if (ViewBag.CategoriasList.Count == 0)
            {
                <p style="color: rgba(255,255,255,0.2); font-size: 12px; text-align: center; padding: 20px 0; margin: 0;">Sin categorías aún</p>
            }
            else
            {
                @foreach (var cat in ViewBag.CategoriasList)
                {
                    <div class="cat-item" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <span style="color: rgba(255,255,255,0.3); font-size: 11px; width: 30px;">#@cat.CategoryId</span>
                        <span style="color: #ffffff; font-size: 13px; flex: 1; padding-left: 8px;">@cat.Name</span>
                        <div style="display: flex; gap: 6px;">
                            <button onclick="abrirEditarCategoria(@cat.CategoryId, '@cat.Name', '@cat.Description')"
                                    style="background: rgba(99,102,241,0.15); color: #6366f1; border: none; border-radius: 6px; padding: 4px 8px; font-size: 11px; cursor: pointer;">
                                <i class="bi bi-pencil-fill"></i>
                            </button>
                            <form method="post" action="/Category/Delete/@cat.CategoryId" style="margin: 0;" onsubmit="return confirm('¿Eliminar esta categoría?')">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        style="background: rgba(248,113,113,0.15); color: #f87171; border: none; border-radius: 6px; padding: 4px 8px; font-size: 11px; cursor: pointer;">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
            <div id="paginacionCats" style="display: flex; justify-content: center; gap: 6px; margin-top: 12px; flex-wrap: wrap;"></div>
        </div>
    </div>
</div>

<!-- MODAL AGREGAR PRODUCTO -->
<div id="modalAgregar" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Agregar Producto</h5>
            <button onclick="document.getElementById('modalAgregar').style.display='none'" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" action="/Product/Create">
            @Html.AntiForgeryToken()
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre del producto</label>
                <input type="text" name="Name" required placeholder="Ej: Cuaderno A4" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Descripción (opcional)</label>
                <input type="text" name="Description" placeholder="Descripción del producto" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio venta (S/)</label>
                    <input type="number" name="SalePrice" required step="0.01" min="0" placeholder="0.00" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio compra (S/)</label>
                    <input type="number" name="PurchasePrice" required step="0.01" min="0" placeholder="0.00" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div id="stockField" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock inicial</label>
                    <input type="number" name="Stock" min="0" placeholder="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock mínimo (alerta)</label>
                    <input type="number" name="MinimumStock" min="0" value="5" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Categoría</label>
                <select name="CategoryId" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Seleccionar categoría --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Value">@cat.Text</option>
                    }
                </select>
            </div>
            <div id="proveedorField" style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Proveedor (opcional)</label>
                <select name="SupplierId" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Sin proveedor --</option>
                    @foreach (var sup in ViewBag.Suppliers)
                    {
                        <option value="@sup.Value">@sup.Text</option>
                    }
                </select>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input type="checkbox" name="IsService" id="checkServicio" value="true" style="width: 18px; height: 18px; accent-color: #6366f1; cursor: pointer;" />
                    <span style="color: rgba(255,255,255,0.8); font-size: 14px;">¿Es un servicio? <span style="color: rgba(255,255,255,0.4); font-size: 12px;">(copias, impresiones, etc.)</span></span>
                </label>
            </div>
            <button type="submit" style="width: 100%; padding: 13px; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 14px; font-weight: 600; letter-spacing: 1px; cursor: pointer; margin-top: 10px;">
                <i class="bi bi-check-lg"></i> Guardar Producto
            </button>
        </form>
    </div>
</div>

<!-- MODAL NUEVA CATEGORIA -->
<div id="modalNuevaCategoria" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 400px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Nueva Categoría</h5>
            <button onclick="document.getElementById('modalNuevaCategoria').style.display='none'" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" action="/Category/Create">
            @Html.AntiForgeryToken()
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre</label>
                <input type="text" name="Name" required placeholder="Ej: Útiles escolares"
                       style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="margin-bottom: 18px;">

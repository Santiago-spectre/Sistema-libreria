@model List<SistemaWebPapeleria.Models.Product>
@{
    ViewData["Title"] = "Productos";
    ViewData["Active"] = "Product";
}

<!-- TOPBAR -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <p style="color: rgba(255,255,255,0.4); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Gestión de inventario</p>
        <h4 style="color: #ffffff; font-weight: 700; font-size: 24px;">Productos</h4>
    </div>
    <button onclick="document.getElementById('modalAgregar').style.display='flex'" class="btn-add">
        <i class="bi bi-plus-lg"></i> Agregar Producto
    </button>
</div>

<!-- BARRA DE BÚSQUEDA -->
<div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
    <input type="text" id="searchInput" placeholder=" Buscar Producto..." style="flex: 1; min-width: 200px; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
    <select id="filterTipo" style="padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
        <option value="">Todos los tipos</option>
        <option value="Producto">Producto</option>
        <option value="Servicio">Servicio</option>
    </select>
    <select id="filterEstado" style="padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
        <option value="">Todos los estados</option>
        <option value="Activo">Activo</option>
        <option value="Inactivo">Inactivo</option>
    </select>
</div>

<!-- TABLA DE PRODUCTOS -->
<div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 25px;">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.07);">
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Nombre</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Categoría</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Tipo</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Precio Venta</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Stock</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Estado</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                    <td style="color: #ffffff; font-size: 13px; padding: 12px 15px;">@product.Name</td>
                    <td style="color: rgba(255,255,255,0.6); font-size: 13px; padding: 12px 15px;">@product.Category?.Name</td>
                    <td style="padding: 12px 15px;">
                        @if (product.IsService)
                        {
                            <span class="badge-service">Servicio</span>
                        }
                        else
                        {
                            <span class="badge-product">Producto</span>
                        }
                    </td>
                    <td style="color: #34d399; font-size: 13px; font-weight: 700; padding: 12px 15px;">S/ @product.SalePrice</td>
                    <td style="padding: 12px 15px;">
                        @if (!product.IsService && product.Stock <= product.MinimumStock)
                        {
                            <span class="badge-low">⚠ @product.Stock unid.</span>
                        }
                        else if (product.IsService)
                        {
                            <span style="color: rgba(255,255,255,0.3); font-size: 13px;">-</span>
                        }
                        else
                        {
                            <span style="color: rgba(255,255,255,0.6); font-size: 13px;">@product.Stock unid.</span>
                        }
                    </td>
                    <td style="padding: 12px 15px;">
                        @if (product.IsActive)
                        {
                            <span class="badge-active">Activo</span>
                        }
                        else
                        {
                            <span class="badge-inactive">Inactivo</span>
                        }
                    </td>
                    <td style="padding: 12px 15px;">
                        <div style="display: flex; gap: 8px;">
                            <a href="/Product/Edit/@product.ProductId" style="background: rgba(99,102,241,0.15); color: #6366f1; padding: 6px 12px; border-radius: 8px; font-size: 12px; text-decoration: none;">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="/Product/ToggleStatus/@product.ProductId" style="margin: 0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background: rgba(248,113,113,0.15); color: #f87171; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                    @if (product.IsActive)
                                    {
                                        <i class="bi bi-eye-slash-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-eye-fill"></i>
                                    }
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div id="paginacion" style="display: flex; justify-content: center; gap: 6px; margin-top: 20px;"></div>
</div>

<!-- MODAL AGREGAR PRODUCTO -->
<div id="modalAgregar" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Agregar Producto</h5>
            <button onclick="document.getElementById('modalAgregar').style.display='none'" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" action="/Product/Create">
            @Html.AntiForgeryToken()
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre del producto</label>
                <input type="text" name="Name" required placeholder="Ej: Cuaderno A4" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio venta (S/)</label>
                    <input type="number" name="SalePrice" required step="0.01" min="0" placeholder="0.00" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio compra (S/)</label>
                    <input type="number" name="PurchasePrice" required step="0.01" min="0" placeholder="0.00" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div id="stockField" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock inicial</label>
                    <input type="number" name="Stock" required min="0" placeholder="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock mínimo (alerta)</label>
                    <input type="number" name="MinimumStock" required min="0" value="5" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Categoría</label>
                <select name="CategoryId" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Seleccionar categoría --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Value">@cat.Text</option>
                    }
                </select>
            </div>
            <div id="proveedorField" style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Proveedor (opcional)</label>
                <select name="SupplierId" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Sin proveedor --</option>
                    @foreach (var sup in ViewBag.Suppliers)
                    {
                        <option value="@sup.Value">@sup.Text</option>
                    }
                </select>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input type="checkbox" name="IsService" id="checkServicio" value="true" style="width: 18px; height: 18px; accent-color: #6366f1; cursor: pointer;" />
                    <span style="color: rgba(255,255,255,0.8); font-size: 14px;">¿Es un servicio? <span style="color: rgba(255,255,255,0.4); font-size: 12px;">(copias, impresiones, etc.)</span></span>
                </label>
            </div>
            <button type="submit" style="width: 100%; padding: 13px; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 14px; font-weight: 600; letter-spacing: 1px; cursor: pointer; margin-top: 10px;">
                <i class="bi bi-check-lg"></i> Guardar Producto
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const filterTipo = document.getElementById('filterTipo');
        const filterEstado = document.getElementById('filterEstado');
        const rowsPerPage = 10;
        let currentPage = 1;

        function getFilasVisibles() {
            const texto = searchInput.value.toLowerCase();
            const tipo = filterTipo.value.toLowerCase();
            const estado = filterEstado.value.toLowerCase();
            const filas = Array.from(document.querySelectorAll('tbody tr'));
            return filas.filter(fila => {
                const nombre = fila.cells[0].textContent.toLowerCase();
                const tipoCelda = fila.cells[2].textContent.trim().toLowerCase();
                const estadoCelda = fila.cells[5].textContent.trim().toLowerCase();
                return nombre.includes(texto) && (tipo === '' || tipoCelda.includes(tipo)) && (estado === '' || estadoCelda.includes(estado));
            });
        }

        function renderPagina() {
            const filas = Array.from(document.querySelectorAll('tbody tr'));
            const visibles = getFilasVisibles();
            filas.forEach(f => f.style.display = 'none');
            const inicio = (currentPage - 1) * rowsPerPage;
            const fin = inicio + rowsPerPage;
            visibles.slice(inicio, fin).forEach(f => f.style.display = '');
            renderPaginacion(visibles.length);
        }

        function renderPaginacion(total) {
            const totalPaginas = Math.ceil(total / rowsPerPage);
            let paginacion = document.getElementById('paginacion');
            paginacion.innerHTML = '';
            if (totalPaginas <= 1) return;
            const btnAnterior = document.createElement('button');
            btnAnterior.textContent = '‹';
            btnAnterior.disabled = currentPage === 1;
            btnAnterior.onclick = () => { currentPage--; renderPagina(); };
            paginacion.appendChild(btnAnterior);
            for (let i = 1; i <= totalPaginas; i++) {
                const btn = document.createElement('button');
                btn.textContent = i;
                if (i === currentPage) btn.classList.add('active');
                btn.onclick = () => { currentPage = i; renderPagina(); };
                paginacion.appendChild(btn);
            }
            const btnSiguiente = document.createElement('button');
            btnSiguiente.textContent = '›';
            btnSiguiente.disabled = currentPage === totalPaginas;
            btnSiguiente.onclick = () => { currentPage++; renderPagina(); };
            paginacion.appendChild(btnSiguiente);
        }

        function filtrar() { currentPage = 1; renderPagina(); }

        searchInput.addEventListener('input', filtrar);
        filterTipo.addEventListener('change', filtrar);
        filterEstado.addEventListener('change', filtrar);
        renderPagina();

        const checkServicio = document.getElementById('checkServicio');
        const stockField = document.getElementById('stockField');
        const proveedorField = document.getElementById('proveedorField');
        checkServicio.addEventListener('change', function () {
            stockField.style.display = this.checked ? 'none' : 'grid';
            proveedorField.style.display = this.checked ? 'none' : 'block';
        });
    </script>
}
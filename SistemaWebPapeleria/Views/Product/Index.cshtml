<!-- MODAL EDITAR PRODUCTO -->
<div id="modalEditarProducto" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Editar Producto</h5>
            <button onclick="document.getElementById('modalEditarProducto').style.display='none'" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" id="formEditarProducto">
            @Html.AntiForgeryToken()
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre del producto</label>
                <input type="text" name="Name" id="editNombre" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Descripción (opcional)</label>
                <input type="text" name="Description" id="editDescripcion" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio venta (S/)</label>
                    <input type="number" name="SalePrice" id="editPrecioVenta" required step="0.01" min="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Precio compra (S/)</label>
                    <input type="number" name="PurchasePrice" id="editPrecioCompra" required step="0.01" min="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div id="editStockField" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock</label>
                    <input type="number" name="Stock" id="editStock" min="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Stock mínimo</label>
                    <input type="number" name="MinimumStock" id="editStockMinimo" min="0" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Categoría</label>
                <select name="CategoryId" id="editCategoria" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Seleccionar categoría --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Value">@cat.Text</option>
                    }
                </select>
            </div>
            <div id="editProveedorField" style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Proveedor (opcional)</label>
                <select name="SupplierId" id="editProveedor" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Sin proveedor --</option>
                    @foreach (var sup in ViewBag.Suppliers)
                    {
                        <option value="@sup.Value">@sup.Text</option>
                    }
                </select>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input type="checkbox" name="IsService" id="editCheckServicio" value="true" style="width: 18px; height: 18px; accent-color: #6366f1; cursor: pointer;" />
                    <span style="color: rgba(255,255,255,0.8); font-size: 14px;">¿Es un servicio?</span>
                </label>
            </div>
            <button type="submit" style="width: 100%; padding: 13px; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 14px; font-weight: 600; letter-spacing: 1px; cursor: pointer; margin-top: 10px;">
                <i class="bi bi-check-lg"></i> Guardar Cambios
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const filterTipo = document.getElementById('filterTipo');
        const filterEstado = document.getElementById('filterEstado');
        const rowsPerPage = 10;
        let currentPage = 1;

        function getFilasVisibles() {
            const texto = searchInput.value.toLowerCase();
            const tipo = filterTipo.value.toLowerCase();
            const estado = filterEstado.value.toLowerCase();
            const filas = Array.from(document.querySelectorAll('tbody tr'));
            return filas.filter(fila => {
                const nombre = fila.cells[0].textContent.toLowerCase();
                const tipoCelda = fila.cells[2].textContent.trim().toLowerCase();
                const estadoCelda = fila.cells[5].textContent.trim().toLowerCase();
                return nombre.includes(texto) && (tipo === '' || tipoCelda.includes(tipo)) && (estado === '' || estadoCelda.includes(estado));
            });
        }

        function renderPagina() {
            const filas = Array.from(document.querySelectorAll('tbody tr'));
            const visibles = getFilasVisibles();
            filas.forEach(f => f.style.display = 'none');
            const inicio = (currentPage - 1) * rowsPerPage;
            const fin = inicio + rowsPerPage;
            visibles.slice(inicio, fin).forEach(f => f.style.display = '');
            renderPaginacion(visibles.length);
        }

        function renderPaginacion(total) {
            const totalPaginas = Math.ceil(total / rowsPerPage);
            let paginacion = document.getElementById('paginacion');
            paginacion.innerHTML = '';
            if (totalPaginas <= 1) return;
            const btnStyle = 'background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #ffffff; padding: 5px 11px; font-size: 13px; cursor: pointer;';
            const btnActiveStyle = 'background: rgba(99,102,241,0.4); border: 1px solid #6366f1; border-radius: 8px; color: #ffffff; padding: 5px 11px; font-size: 13px; cursor: pointer; font-weight: 700;';
            
            const btnAnterior = document.createElement('button');
            btnAnterior.textContent = '‹';
            btnAnterior.style.cssText = btnStyle;
            btnAnterior.disabled = currentPage === 1;
            btnAnterior.onclick = () => { currentPage--; renderPagina(); };
            paginacion.appendChild(btnAnterior);
            
            for (let i = 1; i <= totalPaginas; i++) {
                const btn = document.createElement('button');
                btn.textContent = i;
                btn.style.cssText = i === currentPage ? btnActiveStyle : btnStyle;
                btn.onclick = () => { currentPage = i; renderPagina(); };
                paginacion.appendChild(btn);
            }

            const btnSiguiente = document.createElement('button');
            btnSiguiente.textContent = '›';
            btnSiguiente.style.cssText = btnStyle;
            btnSiguiente.disabled = currentPage === totalPaginas;
            btnSiguiente.onclick = () => { currentPage++; renderPagina(); };
            paginacion.appendChild(btnSiguiente);
        }

        function filtrar() { currentPage = 1; renderPagina(); }

        searchInput.addEventListener('input', filtrar);
        filterTipo.addEventListener('change', filtrar);
        filterEstado.addEventListener('change', filtrar);
        renderPagina();

        const checkServicio = document.getElementById('checkServicio');
        const stockField = document.getElementById('stockField');
        const proveedorField = document.getElementById('proveedorField');
        checkServicio.addEventListener('change', function () {
            stockField.style.display = this.checked ? 'none' : 'grid';
            proveedorField.style.display = this.checked ? 'none' : 'block';
        });

                // ── Paginación categorías ──
        const catsPorPagina = 9;
        let catPaginaActual = 1;
        const todasCats = document.querySelectorAll('.cat-item');

        function renderCats() {
            const total = todasCats.length;
            const inicio = (catPaginaActual - 1) * catsPorPagina;
            const fin = inicio + catsPorPagina;
            todasCats.forEach((c, i) => c.style.display = (i >= inicio && i < fin) ? 'flex' : 'none');
            renderPaginacionCats(total);
        }

        function renderPaginacionCats(total) {
            const totalPaginas = Math.ceil(total / catsPorPagina);
            const cont = document.getElementById('paginacionCats');
            cont.innerHTML = '';
            if (totalPaginas <= 1) return;

            const btnStyle = 'background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #ffffff; padding: 4px 10px; font-size: 12px; cursor: pointer;';
            const btnActiveStyle = 'background: rgba(99,102,241,0.4); border: 1px solid #6366f1; border-radius: 8px; color: #ffffff; padding: 4px 10px; font-size: 12px; cursor: pointer; font-weight: 700;';

            const btnAnt = document.createElement('button');
            btnAnt.textContent = '‹';
            btnAnt.style.cssText = btnStyle;
            btnAnt.disabled = catPaginaActual === 1;
            btnAnt.onclick = () => { catPaginaActual--; renderCats(); };
            cont.appendChild(btnAnt);

            for (let i = 1; i <= totalPaginas; i++) {
                const btn = document.createElement('button');
                btn.textContent = i;
                btn.style.cssText = i === catPaginaActual ? btnActiveStyle : btnStyle;
                btn.onclick = () => { catPaginaActual = i; renderCats(); };
                cont.appendChild(btn);
            }

            const btnSig = document.createElement('button');
            btnSig.textContent = '›';
            btnSig.style.cssText = btnStyle;
            btnSig.disabled = catPaginaActual === totalPaginas;
            btnSig.onclick = () => { catPaginaActual++; renderCats(); };
            cont.appendChild(btnSig);
        }
        
        renderCats();

        function abrirEditarCategoria(id, nombre, descripcion) {
            document.getElementById('editCategoriaNombre').value = nombre;
            document.getElementById('editCategoriaDescripcion').value = descripcion;
            document.getElementById('formEditarCategoria').action = '/Category/Edit/' + id;
            document.getElementById('modalEditarCategoria').style.display = 'flex';
        }
        
        function abrirEditarProducto(id, nombre, descripcion, precioVenta, precioCompra, stock, stockMinimo, esServicio, categoriaId, proveedorId) {
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editDescripcion').value = descripcion;
            document.getElementById('editPrecioVenta').value = precioVenta;
            document.getElementById('editPrecioCompra').value = precioCompra;
            document.getElementById('editStock').value = stock;
            document.getElementById('editStockMinimo').value = stockMinimo;
            document.getElementById('editCategoria').value = categoriaId;
            document.getElementById('editProveedor').value = proveedorId;

            const checkServ = document.getElementById('editCheckServicio');
            checkServ.checked = esServicio;
            document.getElementById('editStockField').style.display = esServicio ? 'none' : 'grid';
            document.getElementById('editProveedorField').style.display = esServicio ? 'none' : 'block';

            checkServ.onchange = function() {
                document.getElementById('editStockField').style.display = this.checked ? 'none' : 'grid';
                document.getElementById('editProveedorField').style.display = this.checked ? 'none' : 'block';
            };

            document.getElementById('formEditarProducto').action = '/Product/Edit/' + id;
            document.getElementById('modalEditarProducto').style.display = 'flex';
        }
    </script>
}
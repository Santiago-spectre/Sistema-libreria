@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    ViewData["Active"] = "";
    Layout = "_Layout";
}

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;">
    <div style="background:rgba(248,113,113,0.1);width:90px;height:90px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:25px;">
        <i class="bi bi-exclamation-triangle-fill" style="color:#f87171;font-size:40px;"></i>
    </div>
    <h2 style="color:#ffffff;font-weight:700;font-size:28px;margin-bottom:10px;">Algo salió mal</h2>
    <p style="color:rgba(255,255,255,0.45);font-size:15px;margin-bottom:30px;max-width:400px;line-height:1.6;">
        Ocurrió un error inesperado. Por favor intenta de nuevo o contacta al administrador si el problema persiste.
    </p>
    @if (Model?.ShowRequestId == true)
    {
        <p style="color:rgba(255,255,255,0.25);font-size:12px;margin-bottom:20px;">ID: @Model.RequestId</p>
    }
    <a href="/Home/Index" style="background:linear-gradient(135deg,#4f46e5,#6366f1);color:#fff;padding:12px 30px;border-radius:10px;font-weight:600;font-size:14px;text-decoration:none;">
        <i class="bi bi-house-fill"></i> Volver al inicio
    </a>
</div>
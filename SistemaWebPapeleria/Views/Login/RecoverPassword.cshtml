@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;
    var success = Context.Request.Query["success"].ToString();
    var step = "email";
    var codeVerifiedSession = HttpContextAccessor.HttpContext!.Session.GetString("CodeVerified");
    var codeVerifiedTemp = TempData["CodeVerified"]?.ToString();

    if (TempData["InfoRecover"] != null) step = "code";
    if (codeVerifiedSession == "true" || codeVerifiedTemp == "true") step = "reset";

    var errorRecover = TempData["ErrorRecover"]?.ToString();
    var errorVerify = TempData["ErrorVerify"]?.ToString();
    var errorReset = TempData["ErrorReset"]?.ToString();
    var infoRecover = TempData["InfoRecover"]?.ToString();
}

<!DOCTYPE html>
<html>
<head>
    <title>Recuperar Contraseña - Papelería Sonia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%) !important;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        
        .card {
            width: 420px;
            max-width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 40px 35px;
            box-shadow: 0 0 40px rgba(99,102,241,0.2), 0 0 80px rgba(99,102,241,0.1);
        }
        
        label {
            color: rgba(255,255,255,0.6);
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        input.form-control {
            background: rgba(255,255,255,0.07) !important;
            border: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 10px;
            color: #ffffff !important;
            padding: 12px 15px;
        }
        
        .form-control:focus {
            background: rgba(255,255,255,0.1);
            border-color: rgba(100,149,237,0.6);
            box-shadow: 0 0 0 3px rgba(100,149,237,0.15);
        }
        .form-control::placeholder {
            color: rgba(255,255,255,0.25);
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-size: 14px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600;
        }
        
        .btn-primary:hover {
            opacity: 0.85;
            background: linear-gradient(135deg, #4f46e5, #6366f1);
        }
        
        .back-link {
            color: rgba(99,102,241,0.8);
            font-size: 13px;
            text-decoration: none;
        }
        
        .back-link:hover {
            color: #818cf8;
        }
    </style>
</head>
<body>
    <nav style="position:fixed; top:0; left:0; width:100%; padding:15px 30px; display:flex; align-items:center; background:rgba(255,255,255,0.03); border-bottom:1px solid rgba(255,255,255,0.07); backdrop-filter:blur(10px);">
        <img src="~/images/logo1.jpg" alt="Logo" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:10px;" />
        <span style="color:#ffffff; font-weight:700; letter-spacing:2px; text-transform:uppercase; font-size:14px;">Papelería Sonia</span>
    </nav>

    <div class="card">

        @* ── PASO 1: Ingresar correo ── *@
        @if (step == "email")
        {
            <div style="text-align:center; margin-bottom:25px;">
                <div style="width:60px; height:60px; background:rgba(99,102,241,0.15); border:1px solid rgba(99,102,241,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 15px;">
                    <i class="bi bi-envelope-fill" style="color:#818cf8; font-size:24px;"></i>
                </div>
                <h4 style="color:#ffffff; font-weight:700; letter-spacing:1px; text-transform:uppercase; font-size:22px;">Recuperar Contraseña</h4>
                <p style="color:rgba(255,255,255,0.45); font-size:13px; margin-top:8px;">Ingresa tu correo y te enviaremos un código de verificación.</p>
            </div>

            @if (success == "true")
            {
                <div style="background:rgba(52,211,153,0.1); border:1px solid rgba(52,211,153,0.3); border-radius:10px; color:#34d399; font-size:13px; padding:12px 15px; margin-bottom:15px; text-align:center;">
                    <i class="bi bi-check-circle-fill me-2"></i>¡Contraseña restablecida correctamente! Ya puedes iniciar sesión.
                </div>
            }

            @if (!string.IsNullOrEmpty(errorRecover))
            {
                <div class="alert" style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3); border-radius:10px; color:#f87171; font-size:13px; padding:12px 15px; margin-bottom:15px;">
                    <i class="bi bi-x-circle-fill me-2"></i>@errorRecover
                </div>
            }

            <form method="post" asp-action="SendCode" asp-controller="Login">
                <div class="mb-4">
                    <label>Correo Electrónico</label>
                    <div style="position:relative;">
                        <input class="form-control" type="email" name="email" placeholder="Ingrese su correo" required style="padding-right:45px;" />
                        <i class="bi bi-envelope" style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3); font-size:16px;"></i>
                    </div>
                </div>
                <div class="d-grid mb-3">
                    <button class="btn btn-primary" type="submit">
                        Enviar Código &nbsp;<i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
            <div style="text-align:center;">
                <a href="/Login/Login" class="back-link"><i class="bi bi-arrow-left me-1"></i>Volver al inicio de sesión</a>
            </div>
        }

        @* ── PASO 2: Ingresar código ── *@
        @if (step == "code")
        {
            <div style="text-align:center; margin-bottom:25px;">
                <div style="width:60px; height:60px; background:rgba(99,102,241,0.15); border:1px solid rgba(99,102,241,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 15px;">
                    <i class="bi bi-shield-lock-fill" style="color:#818cf8; font-size:24px;"></i>
                </div>
                <h4 style="color:#ffffff; font-weight:700; letter-spacing:1px; text-transform:uppercase; font-size:22px;">Verificar Código</h4>
                <p style="color:rgba(255,255,255,0.45); font-size:13px; margin-top:8px;">Ingresa el código de 6 dígitos que enviamos a tu correo.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorVerify))
            {
                <div class="alert" style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3); border-radius:10px; color:#f87171; font-size:13px; padding:12px 15px; margin-bottom:15px;">
                    <i class="bi bi-x-circle-fill me-2"></i>@errorVerify
                </div>
            }
            @if (!string.IsNullOrEmpty(infoRecover))
            {
                <div class="alert" style="background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.3); border-radius:10px; color:#818cf8; font-size:13px; padding:12px 15px; margin-bottom:15px;">
                    <i class="bi bi-info-circle-fill me-2"></i>@infoRecover
                </div>
            }

            <form method="post" asp-action="VerifyCode" asp-controller="Login">
                <div class="mb-4">
                    <label>Código de Verificación</label>
                    <input class="form-control text-center" type="text" name="code" placeholder="000000"
                           maxlength="6" required style="font-size:24px; letter-spacing:8px; font-weight:700;" />
                </div>
                <div class="d-grid mb-3">
                    <button class="btn btn-primary" type="submit">
                        Verificar Código &nbsp;<i class="bi bi-check-circle-fill"></i>
                    </button>
                </div>
            </form>
            <div style="text-align:center;">
                <a href="/Login/Login" class="back-link"><i class="bi bi-arrow-left me-1"></i>Volver al inicio de sesión</a>
            </div>
        }

        @* ── PASO 3: Nueva contraseña ── *@
        @if (step == "reset")
        {
            <div style="text-align:center; margin-bottom:25px;">
                <div style="width:60px; height:60px; background:rgba(99,102,241,0.15); border:1px solid rgba(99,102,241,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 15px;">
                    <i class="bi bi-key-fill" style="color:#818cf8; font-size:24px;"></i>
                </div>
                <h4 style="color:#ffffff; font-weight:700; letter-spacing:1px; text-transform:uppercase; font-size:22px;">Nueva Contraseña</h4>
                <p style="color:rgba(255,255,255,0.45); font-size:13px; margin-top:8px;">Ingresa y confirma tu nueva contraseña.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorReset))
            {
                <div class="alert" style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3); border-radius:10px; color:#f87171; font-size:13px; padding:12px 15px; margin-bottom:15px;">
                    <i class="bi bi-x-circle-fill me-2"></i>@errorReset
                </div>
            }

            <form method="post" asp-action="ResetPassword" asp-controller="Login">
                <div class="mb-3">
                    <label>Nueva Contraseña</label>
                    <div style="position:relative;">
                        <input class="form-control" type="password" name="newPassword" id="newPassword"
                               placeholder="Ingrese nueva contraseña" required style="padding-right:45px;" />
                        <i class="bi bi-eye-slash-fill" id="toggleNew"
                           onclick="togglePass('newPassword','toggleNew')"
                           style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3); font-size:16px; cursor:pointer;"></i>
                    </div>
                </div>
                <div class="mb-4">
                    <label>Repetir Contraseña</label>
                    <div style="position:relative;">
                        <input class="form-control" type="password" name="repeatPassword" id="repeatPassword"
                               placeholder="Repita la contraseña" required style="padding-right:45px;" />
                        <i class="bi bi-eye-slash-fill" id="toggleRepeat"
                           onclick="togglePass('repeatPassword','toggleRepeat')"
                           style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3); font-size:16px; cursor:pointer;"></i>
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button class="btn btn-primary" type="submit">
                        Restablecer Contraseña &nbsp;<i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </form>
        }

        @* ── PASO 4: Éxito ── *@
        @if (step == "success")
        {
            <div style="text-align:center; padding:10px 0;">
                <div style="width:70px; height:70px; background:rgba(52,211,153,0.12); border:1px solid rgba(52,211,153,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                    <i class="bi bi-check-lg" style="color:#34d399; font-size:32px;"></i>
                </div>
                <h4 style="color:#ffffff; font-weight:700; letter-spacing:1px; text-transform:uppercase; font-size:22px;">¡Contraseña Restablecida!</h4>
                <p style="color:rgba(255,255,255,0.45); font-size:13px; margin-top:10px; margin-bottom:30px;">Tu contraseña fue actualizada correctamente. Ya puedes iniciar sesión con tu nueva contraseña.</p>
                <a href="/Login/Login" class="btn btn-primary w-100">
                    Ir al Inicio de Sesión &nbsp;<i class="bi bi-arrow-right"></i>
                </a>
            </div>
        }

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        function togglePass(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('bi-eye-slash-fill');
        icon.classList.add('bi-eye-fill');
        } else {
        input.type = 'password';
        icon.classList.remove('bi-eye-fill');
        icon.classList.add('bi-eye-slash-fill');
        }
        }
    </script>
</body>
</html>
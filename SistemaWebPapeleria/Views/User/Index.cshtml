@model List<SistemaWebPapeleria.Models.User>
@{
    ViewData["Title"] = "Usuarios";
    ViewData["Active"] = "User";
    var userRole = Context.Session.GetString("UserRole");
}

@if (TempData["Error"] != null)
{
    <div style="background: rgba(248,113,113,0.15); border: 1px solid #f87171; color: #f87171; padding: 12px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 13px;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div style="background: rgba(52,211,153,0.15); border: 1px solid #34d399; color: #34d399; padding: 12px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 13px;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<!-- TOPBAR -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <p style="color: rgba(255,255,255,0.4); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Gestión de usuarios</p>
        <h4 style="color: #ffffff; font-weight: 700; font-size: 24px;">Usuarios</h4>
    </div>
    @if (userRole == "Administrador")
    {
        <button onclick="document.getElementById('modalAgregar').style.display='flex'" style="background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; letter-spacing: 1px; padding: 10px 20px; display: inline-flex; align-items: center; gap: 8px; cursor: pointer;">
            <i class="bi bi-plus-lg"></i> Agregar Usuario
        </button>
    }
</div>

<!-- TABLA -->
<div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(99,102,241,0.1); border-radius: 15px; padding: 25px;">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.07);">
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Nombre</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Email</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Rol</th>
                <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Estado</th>
                @if (userRole == "Administrador")
                {
                    <th style="color: rgba(255,255,255,0.4); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 10px 15px; text-align: left;">Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                    <td style="color: #ffffff; font-size: 13px; padding: 12px 15px;">@user.Name @user.LastName</td>
                    <td style="color: rgba(255,255,255,0.6); font-size: 13px; padding: 12px 15px;">@user.Email</td>
                    <td style="padding: 12px 15px;">
                        <span style="background: rgba(99,102,241,0.15); color: #818cf8; padding: 4px 10px; border-radius: 20px; font-size: 11px;">@user.Role?.RoleName</span>
                    </td>
                    <td style="padding: 12px 15px;">
                        @if (user.Status)
                        {
                            <span style="background: rgba(52,211,153,0.15); color: #34d399; padding: 4px 10px; border-radius: 20px; font-size: 11px;">Activo</span>
                        }
                        else
                        {
                            <span style="background: rgba(255,80,80,0.15); color: #ff5050; padding: 4px 10px; border-radius: 20px; font-size: 11px;">Inactivo</span>
                        }
                    </td>
                    @if (userRole == "Administrador")
                    {
                        <td style="padding: 12px 15px;">
                            <div style="display: flex; gap: 8px;">
                                <button onclick="abrirEditar(@user.UserId, '@user.Name', '@user.LastName', '@user.Email', @user.RoleId)" style="background: rgba(99,102,241,0.15); color: #6366f1; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>
                                <form method="post" action="/User/ToggleStatus/@user.UserId" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background: rgba(251,191,36,0.15); color: #fbbf24; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                        @if (user.Status)
                                        {
                                            <i class="bi bi-eye-slash-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-eye-fill"></i>
                                        }
                                    </button>
                                </form>
                                <form method="post" action="/User/Delete/@user.UserId" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" onclick="return confirm('¿Seguro que quieres eliminar este usuario?')" style="background: rgba(248,113,113,0.15); color: #f87171; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: none; cursor: pointer;">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 50px 20px;">
            <i class="bi bi-person-fill" style="font-size: 40px; color: rgba(99,102,241,0.4); display: block; margin-bottom: 12px;"></i>
            <p style="color: rgba(255,255,255,0.3); font-size: 14px;">No hay usuarios registrados</p>
        </div>
    }
</div>

<!-- MODAL AGREGAR USUARIO -->
<div id="modalAgregar" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Agregar Usuario</h5>
            <button onclick="cerrarModalAgregarUsuario()" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        
        <form method="post" action="/User/Create" id="formCrearUsuario" onsubmit="return validarPasswordsCrear()">
            @Html.AntiForgeryToken()

            <!-- PASO 1: Correo -->
            <div id="pasoCorreo" style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Email</label>
                <div style="display: flex; gap: 10px;">
                    <input type="email" name="Email" id="inputEmailCrear" required placeholder="Ej: juan@correo.com" style="flex: 1; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <button type="button" onclick="enviarCodigoCrearUsuario()" id="btnVerificarCorreo" style="background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; padding: 0 18px; cursor: pointer;">
                        Verificar
                    </button>
                </div>
            </div>

            <!-- PASO 2: Código (oculto hasta enviar) -->
            <div id="pasoCodigo" style="display: none; margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Código de verificación</label>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="inputCodigoCrear" maxlength="6" placeholder="6 dígitos" style="flex: 1; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <button type="button" onclick="confirmarCodigoCrearUsuario()" style="background: linear-gradient(135deg, #34d399, #10b981); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; padding: 0 18px; cursor: pointer;">
                        Confirmar
                    </button>
                </div>
            </div>

            <!-- PASO 3: Resto de campos (oculto hasta verificar) -->
            <div id="pasoDatos" style="display: none;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                    <div>
                        <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre</label>
                        <input type="text" name="Name" required placeholder="Ej: Juan" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    </div>
                    <div>
                        <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Apellido</label>
                        <input type="text" name="LastName" required placeholder="Ej: Pérez" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    </div>
                </div>
                <div style="margin-bottom: 18px;">
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Contraseña</label>
                    <div style="position: relative;">
                        <input type="password" name="Password" id="crearPassword" required placeholder="Contraseña" style="width: 100%; padding: 12px 45px 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                        <i class="bi bi-eye-fill" onclick="togglePassword('crearPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 16px; cursor: pointer;"></i>
                    </div>
                </div>
                <div style="margin-bottom: 18px;">
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Repetir contraseña</label>
                    <div style="position: relative;">
                        <input type="password" id="crearConfirmPassword" required placeholder="Repite la contraseña" style="width: 100%; padding: 12px 45px 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                        <i class="bi bi-eye-fill" onclick="togglePassword('crearConfirmPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 16px; cursor: pointer;"></i>
                    </div>
                </div>
                <div style="margin-bottom: 18px;">
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Rol</label>
                    <select name="RoleId" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                        <option value="">-- Seleccionar rol --</option>
                        @foreach (var role in ViewBag.Roles ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                        {
                            <option value="@role.Value">@role.Text</option>
                        }
                    </select>
                </div>
                <button type="submit" style="width: 100%; padding: 13px; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 14px; font-weight: 600; letter-spacing: 1px; cursor: pointer; margin-top: 10px;">
                    <i class="bi bi-check-lg"></i> Guardar Usuario
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL EDITAR USUARIO -->
<div id="modalEditar" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 35px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="color: #ffffff; font-weight: 700; font-size: 18px; margin: 0;">Editar Usuario</h5>
            <button onclick="document.getElementById('modalEditar').style.display='none'" style="background: none; border: none; color: rgba(255,255,255,0.5); font-size: 20px; cursor: pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" action="/User/Edit" onsubmit="return validarPasswordsEditar()">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserId" id="editUserId" />
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nombre</label>
                    <input type="text" name="Name" id="editName" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
                <div>
                    <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Apellido</label>
                    <input type="text" name="LastName" id="editLastName" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Email</label>
                <div style="display: flex; gap: 10px;">
                    <input type="email" name="Email" id="editEmail" required oninput="onEditEmailChange()" style="flex: 1; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <button type="button" id="btnVerificarEditEmail" onclick="enviarCodigoEditarUsuario()" style="display: none; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; padding: 0 18px; cursor: pointer;">
                        Verificar
                    </button>
                </div>
            </div>
            <div id="pasoCodigoEditar" style="display: none; margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Código de verificación</label>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="inputCodigoEditar" maxlength="6" placeholder="6 dígitos" style="flex: 1; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <button type="button" onclick="confirmarCodigoEditarUsuario()" style="background: linear-gradient(135deg, #34d399, #10b981); border: none; border-radius: 10px; color: #ffffff; font-size: 13px; font-weight: 600; padding: 0 18px; cursor: pointer;">
                        Confirmar
                    </button>
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Nueva Contraseña <span style="color: rgba(255,255,255,0.3); font-size: 11px;">(dejar vacío para no cambiar)</span></label>
                <div style="position: relative;">
                    <input type="password" name="Password" id="editPassword" placeholder="Nueva contraseña" style="width: 100%; padding: 12px 45px 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <i class="bi bi-eye-fill" onclick="togglePassword('editPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 16px; cursor: pointer;"></i>
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Repetir contraseña</label>
                <div style="position: relative;">
                    <input type="password" id="editConfirmPassword" placeholder="Repite la nueva contraseña" style="width: 100%; padding: 12px 45px 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;" />
                    <i class="bi bi-eye-fill" onclick="togglePassword('editConfirmPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 16px; cursor: pointer;"></i>
                </div>
            </div>
            <div style="margin-bottom: 18px;">
                <label style="color: rgba(255,255,255,0.6); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 8px;">Rol</label>
                <select name="RoleId" id="editRoleId" required style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #ffffff; font-size: 14px; outline: none;">
                    <option value="">-- Seleccionar rol --</option>
                    @foreach (var role in ViewBag.Roles ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@role.Value">@role.Text</option>
                    }
                </select>
            </div>
            <button type="submit" id="btnGuardarEdicion" style="width: 100%; padding: 13px; background: linear-gradient(135deg, #4f46e5, #6366f1); border: none; border-radius: 10px; color: #ffffff; font-size: 14px; font-weight: 600; letter-spacing: 1px; cursor: pointer; margin-top: 10px;">
                <i class="bi bi-check-lg"></i> Guardar Cambios
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let correoOriginalEditar = '';
        let codigoEditarVerificado = false;

        function abrirEditar(id, nombre, apellido, email, rolId){
            document.getElementById('editUserId').value = id;
            document.getElementById('editName').value = nombre;
            document.getElementById('editLastName').value = apellido;
            document.getElementById('editEmail').value = email;
            document.getElementById('editRoleId').value = rolId;
            document.getElementById('modalEditar').style.display = 'flex';

            correoOriginalEditar = email.toLowerCase();
            codigoEditarVerificado = false;
            document.getElementById('btnVerificarEditEmail').style.display = 'none';
            document.getElementById('pasoCodigoEditar').style.display = 'none';
            document.getElementById('btnGuardarEdicion').disabled = false;
        }

        function onEditEmailChange() {
            const nuevoEmail = document.getElementById('editEmail').value.toLowerCase();
            const btn = document.getElementById('btnVerificarEditEmail');

            if (nuevoEmail !== correoOriginalEditar && nuevoEmail.includes('@@')) {
                btn.style.display = 'inline-block';
                codigoEditarVerificado = false;
                document.getElementById('btnGuardarEdicion').disabled = true;
                document.getElementById('pasoCodigoEditar').style.display = 'none';
            } else {
                btn.style.display = 'none';
                document.getElementById('pasoCodigoEditar').style.display = 'none';
                document.getElementById('btnGuardarEdicion').disabled = false;
            }
        }

        async function enviarCodigoEditarUsuario() {
            const email = document.getElementById('editEmail').value;
            const userId = document.getElementById('editUserId').value;
            const btn = document.getElementById('btnVerificarEditEmail');
            btn.disabled = true;
            btn.textContent = 'Enviando...';

            const formData = new URLSearchParams();
            formData.append('email', email);
            formData.append('userId', userId);

            try {
                const res = await fetch('/User/EnviarCodigoEdicion', { method: 'POST', body: formData });
                const data = await res.json();

                if (res.ok) {
                    showToast(data.mensaje, 'success');
                    document.getElementById('pasoCodigoEditar').style.display = 'block';
                    btn.textContent = 'Reenviar código';
                    btn.disabled = false;
                } else {
                    showToast(data.mensaje || 'Error al enviar el código.', 'error');
                    btn.textContent = 'Verificar';
                    btn.disabled = false;
                }
            } catch (e) {
                showToast('Error de conexión.', 'error');
                btn.textContent = 'Verificar';
                btn.disabled = false;
            }
        }

        async function confirmarCodigoEditarUsuario() {
            const code = document.getElementById('inputCodigoEditar').value;
            if (!code) {
                showToast('Ingresa el código recibido.', 'error');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('code', code);

            try {
                const res = await fetch('/User/VerificarCodigoEdicion', { method: 'POST', body: formData });
                const data = await res.json();

                if (res.ok) {
                    showToast(data.mensaje, 'success');
                    codigoEditarVerificado = true;
                    document.getElementById('btnGuardarEdicion').disabled = false;
                    document.getElementById('pasoCodigoEditar').style.display = 'none';
                    document.getElementById('btnVerificarEditEmail').style.display = 'none';
                } else {
                    showToast(data.mensaje || 'Código incorrecto.', 'error');
                }
            } catch (e) {
                showToast('Error de conexión.', 'error');
            }
        }

        let codigoCrearVerificado = false;

        async function enviarCodigoCrearUsuario() {
            const email = document.getElementById('inputEmailCrear').value;
            if (!email) {
                showToast('Ingresa un correo primero.', 'error');
                return;
            }

            const btn = document.getElementById('btnVerificarCorreo');
            btn.disabled = true;
            btn.textContent = 'Enviando...';

            const formData = new URLSearchParams();
            formData.append('email', email);

            try {
                const res = await fetch('/User/EnviarCodigoVerificacion', { method: 'POST', body: formData });
                const data = await res.json();

                if (res.ok) {
                    showToast(data.mensaje, 'success');
                    document.getElementById('inputEmailCrear').readOnly = true;
                    document.getElementById('pasoCodigo').style.display = 'block';
                    btn.textContent = 'Reenviar código';
                    btn.disabled = false;
                } else {
                    showToast(data.mensaje || 'Error al enviar el código.', 'error');
                    btn.textContent = 'Verificar';
                    btn.disabled = false;
                }
            } catch (e) {
                showToast('Error de conexión.', 'error');
                btn.textContent = 'Verificar';
                btn.disabled = false;
            }
        }

        async function confirmarCodigoCrearUsuario() {
            const code = document.getElementById('inputCodigoCrear').value;
            if (!code) {
                showToast('Ingresa el código recibido.', 'error');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('code', code);

            try {
                const res = await fetch('/User/VerificarCodigoCreacion', { method: 'POST', body: formData });
                const data = await res.json();

                if (res.ok) {
                    showToast(data.mensaje, 'success');
                    document.getElementById('pasoCodigo').style.display = 'none';
                    document.getElementById('pasoDatos').style.display = 'block';
                    document.getElementById('btnVerificarCorreo').style.display = 'none';
                    codigoCrearVerificado = true;
                } else {
                    showToast(data.mensaje || 'Código incorrecto.', 'error');
                }
            } catch (e) {
                showToast('Error de conexión.', 'error');
            }
        }

        // Resetear el formulario al cerrar el modal
        function cerrarModalAgregarUsuario() {
            document.getElementById('formCrearUsuario').reset();
            document.getElementById('pasoCodigo').style.display = 'none';
            document.getElementById('pasoDatos').style.display = 'none';
            document.getElementById('inputEmailCrear').readOnly = false;
            document.getElementById('btnVerificarCorreo').textContent = 'Verificar';
            codigoCrearVerificado = false;
            document.getElementById('modalAgregar').style.display = 'none';
        }

        function validarPasswordsCrear() {
            const pass = document.getElementById('crearPassword').value;
            const confirm = document.getElementById('crearConfirmPassword').value;
            if (pass !== confirm) {
                showToast('Las contraseñas no coinciden.', 'error');
                return false;
            }
            return true;
        }

        function validarPasswordsEditar() {
            const pass = document.getElementById('editPassword').value;
            const confirm = document.getElementById('editConfirmPassword').value;
            if (pass !== confirm) {
                showToast('Las contraseñas no coinciden.', 'error');
                return false;
            }
            return true;
        }
    </script>
}